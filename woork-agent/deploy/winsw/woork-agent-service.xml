<service>
  <id>woork-agent</id>
  <name>Woork Agent Service</name>
  <description>Woork Edge Agent runtime for local RTSP cameras and cloud sync.</description>
  <executable>%BASE%\woork-agent.exe</executable>
  <arguments>run --config C:\ProgramData\WoorkAgent\config.json</arguments>
  <workingdirectory>%BASE%</workingdirectory>
  <log mode="roll-by-size-time">
    <sizeThreshold>10485760</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
    <keepFiles>14</keepFiles>
  </log>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
</service>
